<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_gt_hookah_pricing_rule_tree" model="ir.ui.view">
        <field name="name">gt.hookah.pricing.rule.tree</field>
        <field name="model">gt.hookah.pricing.rule</field>
        <field name="arch" type="xml">
            <list string="Pricing Rules">
                <field name="partner_id"/>
                <field name="product_id"/>
                <field name="special_price"/>
                <field name="company_id"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_gt_hookah_pricing_rule_form" model="ir.ui.view">
        <field name="name">gt.hookah.pricing.rule.form</field>
        <field name="model">gt.hookah.pricing.rule</field>
        <field name="arch" type="xml">
            <form string="Pricing Rule">
                <sheet>
                    <group>
                        <field name="partner_id"/>
                        <field name="product_id"/>
                        <field name="special_price"/>
                        <field name="company_id"/>
                        <field name="active"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_gt_hookah_pricing_rule" model="ir.actions.act_window">
        <field name="name">Pricing Rules</field>
        <field name="res_model">gt.hookah.pricing.rule</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_gt_hookah_pricing_root" name="GT Pricing" sequence="80"/>
    <menuitem id="menu_gt_hookah_pricing_rules" name="Pricing Rules" parent="menu_gt_hookah_pricing_root" action="action_gt_hookah_pricing_rule" sequence="10"/>
</odoo>
