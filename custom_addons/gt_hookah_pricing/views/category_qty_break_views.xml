<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_gt_hookah_category_qty_break_tree" model="ir.ui.view">
        <field name="name">gt.hookah.category.qty.break.tree</field>
        <field name="model">gt.hookah.category.qty.break</field>
        <field name="arch" type="xml">
            <list string="Category Quantity Breaks">
                <field name="categ_id"/>
                <field name="min_qty"/>
                <field name="price"/>
                <field name="company_id"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_gt_hookah_category_qty_break_form" model="ir.ui.view">
        <field name="name">gt.hookah.category.qty.break.form</field>
        <field name="model">gt.hookah.category.qty.break</field>
        <field name="arch" type="xml">
            <form string="Category Quantity Break">
                <sheet>
                    <group>
                        <field name="categ_id"/>
                        <field name="min_qty"/>
                        <field name="price"/>
                        <field name="company_id"/>
                        <field name="active"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_gt_hookah_category_qty_break" model="ir.actions.act_window">
        <field name="name">Category Quantity Breaks</field>
        <field name="res_model">gt.hookah.category.qty.break</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_gt_hookah_category_qty_breaks" name="Category Quantity Breaks" parent="menu_gt_hookah_pricing_root" action="action_gt_hookah_category_qty_break" sequence="30"/>
</odoo>
